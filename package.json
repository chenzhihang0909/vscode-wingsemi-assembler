{
    "icon": "resources/single.png",
    "name": "vscode-wingsemi-assembler",
    "displayName": "Wingsemi Assembler for VSCode",
    "description": "Out-of-the-box C++ online compiler",
    "publisher": "ykiko",
    "repository": {
        "type": "git",
        "url": "https://github.com/16bit-ykiko/vscode-wingsemi-assembler"
    },
    "version": "0.9.9",
    "engines": {
        "vscode": "^1.65.0"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": ["onStartupFinished"],
    "main": "./dist/extension.js",
    "contributes": {
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "wingsemi-assembler",
                    "title": "Wingsemi Assembler",
                    "icon": "resources/icon.svg"
                }
            ]
        },
        "viewsWelcome": [
            {
                "view": "wingsemi-assembler.view",
                "contents": "Wingsemi Assembler is loading..."
            }
        ],
        "views": {
            "wingsemi-assembler": [
                {
                    "id": "wingsemi-assembler.view",
                    "name": "Wingsemi Assembler"
                }
            ]
        },
        "commands": [
            {
                "command": "wingsemi-assembler.CompileAll",
                "title": "Compile All Instances",
                "category": "Wingsemi Assembler",
                "icon": "$(run-all)"
            },
            {
                "command": "wingsemi-assembler.AddSingleInstance",
                "title": "Add New",
                "category": "Wingsemi Assembler",
                "icon": "$(add)"
            },
            {
                "command": "wingsemi-assembler.AddMultiInstance",
                "title": "Add CMake",
                "category": "Wingsemi Assembler",
                "icon": "$(add)"
            },
            {
                "command": "wingsemi-assembler.RemoveAll",
                "title": "Remove All",
                "category": "Wingsemi Assembler",
                "icon": "$(trashcan)"
            },
            {
                "command": "wingsemi-assembler.Remove",
                "title": "Remove Current",
                "category": "Wingsemi Assembler",
                "icon": "$(trashcan)"
            },
            {
                "command": "wingsemi-assembler.Compile",
                "title": "Compile Current",
                "category": "Wingsemi Assembler",
                "icon": "$(run)"
            },
            {
                "command": "wingsemi-assembler.Clone",
                "title": "Clone Current",
                "category": "Wingsemi Assembler",
                "icon": "$(expand-all)"
            },
            {
                "command": "wingsemi-assembler.SelectCompiler",
                "title": "Select Compiler",
                "category": "Wingsemi Assembler",
                "icon": "$(list-selection)"
            },
            {
                "command": "wingsemi-assembler.GetInput",
                "title": "Get Input",
                "category": "Wingsemi Assembler",
                "icon": "$(pencil)"
            },
            {
                "command": "wingsemi-assembler.ClearInput",
                "title": "Clear Input",
                "category": "Wingsemi Assembler",
                "icon": "$(clear-all)"
            },
            {
                "command": "wingsemi-assembler.CopyText",
                "title": "Copy Input",
                "category": "Wingsemi Assembler",
                "icon": "$(clippy)"
            },
            {
                "command": "wingsemi-assembler.OpenTempFile",
                "title": "Open Temp File",
                "category": "Wingsemi Assembler",
                "icon": "$(file)"
            },
            {
                "command": "wingsemi-assembler.SelectFile",
                "title": "Select File",
                "category": "Wingsemi Assembler",
                "icon": "$(file)"
            },
            {
                "command": "wingsemi-assembler.SelectFolder",
                "title": "Select Folder",
                "category": "Wingsemi Assembler",
                "icon": "$(folder)"
            }
        ],
        "menus": {
            "view/title": [
                {
                    "command": "wingsemi-assembler.CompileAll",
                    "when": "view == wingsemi-assembler.view",
                    "group": "navigation@1"
                },
                {
                    "command": "wingsemi-assembler.AddSingleInstance",
                    "when": "view == wingsemi-assembler.view",
                    "group": "navigation@2"
                },
                {
                    "command": "wingsemi-assembler.AddMultiInstance",
                    "when": "view == wingsemi-assembler.view"
                },
                {
                    "command": "wingsemi-assembler.RemoveAll",
                    "when": "view == wingsemi-assembler.view"
                }
            ],
            "view/item/context": [
                {
                    "command": "wingsemi-assembler.Compile",
                    "when": "view == wingsemi-assembler.view && viewItem == instance",
                    "group": "inline@1"
                },
                {
                    "command": "wingsemi-assembler.Clone",
                    "when": "view == wingsemi-assembler.view && viewItem == instance",
                    "group": "inline@2"
                },
                {
                    "command": "wingsemi-assembler.Remove",
                    "when": "view == wingsemi-assembler.view && viewItem == instance",
                    "group": "inline@3"
                },
                {
                    "command": "wingsemi-assembler.SelectCompiler",
                    "when": "view == wingsemi-assembler.view && viewItem == select",
                    "group": "inline"
                },
                {
                    "command": "wingsemi-assembler.GetInput",
                    "when": "view == wingsemi-assembler.view && viewItem == text",
                    "group": "inline@1"
                },
                {
                    "command": "wingsemi-assembler.ClearInput",
                    "when": "view == wingsemi-assembler.view && viewItem == text",
                    "group": "inline@2"
                },
                {
                    "command": "wingsemi-assembler.OpenTempFile",
                    "when": "view == wingsemi-assembler.view && viewItem == text"
                },
                {
                    "command": "wingsemi-assembler.SelectFile",
                    "when": "view == wingsemi-assembler.view && viewItem == text"
                },
                {
                    "command": "wingsemi-assembler.CopyText",
                    "when": "view == wingsemi-assembler.view && (viewItem == select || viewItem == text)"
                },
                {
                    "command": "wingsemi-assembler.SelectFile",
                    "when": "view == wingsemi-assembler.view && viewItem == file",
                    "group": "inline@1"
                },
                {
                    "command": "wingsemi-assembler.SelectFolder",
                    "when": "view == wingsemi-assembler.view && viewItem == folder",
                    "group": "inline@1"
                }
            ]
        },
        "configuration": [
            {
                "title": "Wingsemi-Assembler",
                "properties": {
                    "wingsemi-assembler.default.options": {
                        "type": "object",
                        "description": "The default compiler configuration",
                        "default": {
                            "compiler": "gdefault",
                            "language": "c++",
                            "options": "-std=c++17",
                            "input": "active",
                            "output": "webview",
                            "exec": "",
                            "stdin": "",
                            "cmakeArgs": "",
                            "src": "workspace",
                            "filters": {
                                "binaryObject": false,
                                "binary": false,
                                "execute": false,
                                "intel": true,
                                "demangle": true,
                                "labels": true,
                                "libraryCode": true,
                                "directives": true,
                                "commentOnly": true,
                                "trim": false,
                                "debugCalls": false
                            }
                        }
                    },
                    "wingsemi-assembler.default.color": {
                        "type": "object",
                        "description": "The default color configuration",
                        "default": {
                            "symbol": "#61AFEF",
                            "string": "#98C379",
                            "number": "#D19A66",
                            "register": "#E5C07B",
                            "instruction": "#C678DD",
                            "comment": "#7F848E",
                            "operator": "#ABB2BF"
                        }
                    },
                    "wingsemi-assembler.default.url": {
                        "type": "string",
                        "description": "The default compiler explorer url",
                        "default": ""
                    }
                }
            }
        ]
    },
    "scripts": {
        "install:all": "npm install && cd webview-ui && npm install",
        "start:webview": "cd webview-ui && npm run start",
        "build:webview": "cd webview-ui && npm run build",
        "vscode:prepublish": "npm run package",
        "compile": "webpack",
        "watch": "webpack --watch",
        "webpack": "webpack --mode development",
        "webpack-dev": "webpack --mode development --watch",
        "package": "webpack --mode production --devtool hidden-source-map",
        "package:vsce":"vsce package",
        "test-compile": "tsc -p ./",
        "compile-tests": "tsc -p . --outDir out",
        "watch-tests": "tsc -p . -w --outDir out",
        "pretest": "npm run compile-tests && npm run compile && npm run lint",
        "lint": "eslint src --ext ts",
        "test": "vscode-test"
    },
    "devDependencies": {
        "@types/lodash": "^4.17.0",
        "@types/mocha": "^10.0.6",
        "@types/node": "18.x",
        "@types/vscode": "^1.65.0",
        "@typescript-eslint/eslint-plugin": "^7.4.0",
        "@typescript-eslint/parser": "^7.4.0",
        "@vscode/test-cli": "^0.0.8",
        "@vscode/test-electron": "^2.3.9",
        "eslint": "^8.57.0",
        "ts-loader": "^9.5.1",
        "typescript": "^5.3.3",
        "webpack": "^5.91.0",
        "webpack-cli": "^5.1.4"
    },
    "dependencies": {
        "axios": "^1.6.8",
        "lodash": "^4.17.21"
    }
}
